---
import PostPreview from '@/components/blog/PostPreview.astro';
import SiteBase from '@/layouts/SiteBase.astro';
import siteConfig from '@/site.config';
import { getOrderedBlogPosts } from '@/utils/blog';
import { Icon } from 'astro-icon/components';

const allPostsByDate = await getOrderedBlogPosts();
const postsFiltered = allPostsByDate.slice(0, 5);
---

<SiteBase title="Home">
  <section class="text-base">
    <h1 class="sr-only">Pedro Henrick Queiroz Alves</h1>

    <div class="text-justify">
      <h2 class="text-xl font-serif font-bold">Olá!</h2>
      <p class="mt-3">Meu nome é Pedro Henrick, um desenvolvedor com paixão por open source e self hosting.</p>
      <p class="flex items-center gap-3 mt-4">
        <span>Me encontre em:</span>
        {siteConfig.UserLinks.map((link) => (
          <a href={link.url} target="_blank" aria-label={link.alt}>
            <Icon name={`simple-icons:${link.icon}`} class="text-lg"/>
          </a>
        ))}
      </p>
    </div>
  </section>

  { postsFiltered.length > 0 && (
    <section class="mt-10">
      <h2 class="text-xl font-serif font-bold">Posts recentes</h2>
      <div>
        {postsFiltered.map((post) => <PostPreview post={post} />)}
      </div>
    </section>
  )}
</SiteBase>
