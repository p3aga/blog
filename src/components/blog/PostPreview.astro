---
import type { CollectionEntry } from 'astro:content';
import PostDate from '@/components/blog/PostDate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article class="@container/post-preview my-5">
  <a href={`${import.meta.env.BASE_URL}blog/${post.id}`} class="transition-opacity duration-200 hover:opacity-80">
    <div class="@md/post-preview:flex @md/post-preview:items-center @md/post-preview:gap-4">
      <h3 class="text-base font-semibold whitespace-nowrap text-ellipsis overflow-hidden">
        { post.data.title } {post.data.draft && "(Rascunho)"}
      </h3>
      <div class="flex-1 border-t opacity-30 @max-md/post-preview:hidden"></div>
      <div class="@max-md/post-preview:hidden">
        <PostDate pubDate={ post.data.pubDate } />
      </div>
    </div>
    <div class="text-sm font-medium opacity-50">
      <em>{ post.data.description }</em>
    </div>
    <div class="whitespace-nowrap text-ellipsis overflow-hidden">
      <div class="hidden me-1 after:content-['-'] after:opacity-50 @max-md/post-preview:inline">
        <PostDate pubDate={ post.data.pubDate } />
      </div>
      {
        post.data.tags.map(tag => (
          <span class="text-sm me-1 font-medium inline">#{ tag }</span>
        ))
      }
    </div>
  </a>
</article>
