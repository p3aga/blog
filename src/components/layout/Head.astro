---
import siteConfig from '@/site.config';


interface Props {
  title: string
}

const { title } = Astro.props;
const titleFormated = `${title} | ${siteConfig.SiteName}`
---

<meta charset="utf-8" />
<link rel="sitemap" href={`${import.meta.env.BASE_URL}/sitemap-index.xml`}>
<title>{titleFormated}</title>
<meta name="description" content={siteConfig.Description}>

<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />

{!import.meta.env.DEV && (
  <link href={`${import.meta.env.BASE_URL}/pagefind/pagefind-component-ui.css`} rel="stylesheet">
  <script src={`${import.meta.env.BASE_URL}/pagefind/pagefind-component-ui.js`} is:inline></script>
)}
